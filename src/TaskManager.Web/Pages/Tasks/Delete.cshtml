@page
@model DeleteModel
@{
    ViewData["Title"] = "Delete Task";
}

<div class="row">
    <div class="col-md-6">
        <h1 class="mb-4">Delete Task</h1>

        @if (Model.Task is not null)
        {
            <div class="alert alert-warning">
                Are you sure you want to delete <strong>@Model.Task.Title</strong>?
            </div>
            <form method="post">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-page="/Tasks/Index" asp-route-projectId="@Model.ProjectId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        }
    </div>
</div>
