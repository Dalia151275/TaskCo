@page
@model EditModel
@{
    ViewData["Title"] = "Edit Task";
}

<h1>Edit Task</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-error">@Model.ErrorMessage</div>
}

<form method="post" asp-route-projectId="@Model.ProjectId" asp-route-id="@Model.Id" style="max-width:500px">
    <div class="form-group">
        <label asp-for="Input.Title">Title</label>
        <input asp-for="Input.Title" />
        <span asp-validation-for="Input.Title" class="error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Input.Description">Description</label>
        <textarea asp-for="Input.Description" rows="4"></textarea>
        <span asp-validation-for="Input.Description" class="error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Input.Status">Status</label>
        <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<TaskItemStatus>()"></select>
    </div>
    <div class="form-group">
        <label asp-for="Input.DueDate">Due Date</label>
        <input asp-for="Input.DueDate" type="date" />
    </div>
    <div class="actions">
        <button type="submit" class="btn">Save</button>
        <a asp-page="/Tasks/Index" asp-route-projectId="@Model.ProjectId" class="btn-secondary">Cancel</a>
    </div>
</form>
