@page
@model IndexModel
@{
    ViewData["Title"] = Model.Project?.Name ?? "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-page="/Projects/Index" class="text-decoration-none text-muted small">&larr; Projects</a>
        <h1 class="mb-0">@Model.Project?.Name</h1>
        @if (Model.Project?.Description is not null)
        {
            <p class="text-muted mt-1 mb-0">@Model.Project.Description</p>
        }
    </div>
    <a asp-page="/Tasks/Create" asp-route-projectId="@Model.ProjectId" class="btn btn-primary">New Task</a>
</div>

@if (!Model.Tasks.Any())
{
    <p class="text-muted">No tasks yet. <a asp-page="/Tasks/Create" asp-route-projectId="@Model.ProjectId">Create your first task.</a></p>
}
else
{
    <table class="table table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Due</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Model.Tasks)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>
                        @{
                            var (badgeClass, badgeLabel) = task.Status switch
                            {
                                TaskManager.Web.Models.Entities.TaskStatus.Todo       => ("bg-secondary",        "Todo"),
                                TaskManager.Web.Models.Entities.TaskStatus.InProgress => ("bg-primary",          "In Progress"),
                                TaskManager.Web.Models.Entities.TaskStatus.Done       => ("bg-success",          "Done"),
                                _                                                      => ("bg-secondary",        task.Status.ToString())
                            };
                        }
                        <span class="badge @badgeClass">@badgeLabel</span>
                    </td>
                    <td>@task.Priority</td>
                    <td>@task.DueDate?.ToString("dd-MM-yyyy")</td>
                    <td>
                        <a asp-page="/Tasks/Edit" asp-route-projectId="@Model.ProjectId" asp-route-id="@task.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="/Tasks/Delete" asp-route-projectId="@Model.ProjectId" asp-route-id="@task.Id" class="btn btn-sm btn-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
