<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskManager</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav>
            <a href="/">TaskManager</a>
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-page="/Projects/Index">Projects</a>
                <form method="post" asp-page="/Account/Logout" style="display:inline">
                    <button type="submit" class="btn-link">Logout</button>
                </form>
            }
            else
            {
                <a asp-page="/Account/Login">Login</a>
                <a asp-page="/Account/Register">Register</a>
            }
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
</body>
</html>
