@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>Create Account</h1>

@if (Model.ErrorMessages.Count > 0)
{
    <div class="alert alert-error">
        @foreach (var msg in Model.ErrorMessages)
        {
            <div>@msg</div>
        }
    </div>
}

<form method="post" style="max-width:400px">
    <div class="form-group">
        <label asp-for="Input.Email">Email</label>
        <input asp-for="Input.Email" type="email" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" type="password" autocomplete="new-password" />
        <span asp-validation-for="Input.Password" class="error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Input.ConfirmPassword">Confirm Password</label>
        <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
        <span asp-validation-for="Input.ConfirmPassword" class="error"></span>
    </div>
    <div class="actions">
        <button type="submit" class="btn">Register</button>
        <a asp-page="/Account/Login">Already have an account?</a>
    </div>
</form>
