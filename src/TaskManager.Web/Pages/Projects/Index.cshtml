@page
@model IndexModel
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Projects</h1>
    <a asp-page="/Projects/Create" class="btn btn-primary">New Project</a>
</div>

@if (!Model.Projects.Any())
{
    <p class="text-muted">No projects yet. <a asp-page="/Projects/Create">Create your first project.</a></p>
}
else
{
    <table class="table table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model.Projects)
            {
                <tr>
                    <td><a asp-page="/Tasks/Index" asp-route-projectId="@project.Id" class="text-decoration-none fw-semibold">@project.Name</a></td>
                    <td class="text-muted">@project.Description</td>
                    <td>@project.CreatedAt.ToString("dd-MM-yyyy")</td>
                    <td>
                        <a asp-page="/Projects/Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="/Projects/Delete" asp-route-id="@project.Id" class="btn btn-sm btn-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
