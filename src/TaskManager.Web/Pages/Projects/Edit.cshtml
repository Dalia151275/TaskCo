@page
@model EditModel
@{
    ViewData["Title"] = "Edit Project";
}

<h1>Edit Project</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-error">@Model.ErrorMessage</div>
}

<form method="post" asp-route-id="@Model.Id" style="max-width:500px">
    <div class="form-group">
        <label asp-for="Input.Name">Name</label>
        <input asp-for="Input.Name" />
        <span asp-validation-for="Input.Name" class="error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Input.Description">Description</label>
        <textarea asp-for="Input.Description" rows="4"></textarea>
        <span asp-validation-for="Input.Description" class="error"></span>
    </div>
    <div class="actions">
        <button type="submit" class="btn">Save</button>
        <a asp-page="/Projects/Index" class="btn-secondary">Cancel</a>
    </div>
</form>
