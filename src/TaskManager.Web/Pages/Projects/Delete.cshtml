@page "{id:guid}"
@model DeleteProjectModel
@{
    ViewData["Title"] = "Delete Project";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="card-title h3 mb-4">Delete Project</h1>

                @if (Model.Project is not null)
                {
                    <div class="alert alert-danger">
                        <strong>This action is irreversible.</strong>
                        All tasks in <strong>@Model.Project.Name</strong> will also be permanently deleted.
                    </div>

                    <p>Are you sure you want to delete <strong>@Model.Project.Name</strong>?</p>

                    <form method="post">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">Delete</button>
                            @* Assumption: /Projects/Details/{id} not yet implemented; cancelling to Dashboard. *@
                            <a asp-page="/Dashboard" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
